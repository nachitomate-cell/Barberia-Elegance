{
  "name": "barberia-elegance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "serve . -p 3000 --no-clipboard",
    "start": "serve . -p 3000",
    "build": "cd admin-panel && npm install && npm run build",
    "build:css": "tailwindcss -i input.css -o output.css --minify && tailwindcss -c tailwind-lookbook.config.js -i input.css -o output-lookbook.css --minify",
    "build:css:watch": "tailwindcss -i input.css -o output.css --watch",
    "seed": "node seed-barberos.js"
  },
  "devDependencies": {
    "csv-parse": "^7.0.0",
    "firebase-admin": "^13.8.0",
    "playwright": "^1.61.1",
    "serve": "^14.2.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0"
  }
}
