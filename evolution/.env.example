# Copia este archivo a `.env` en el VPS y rellena los valores.
# NO commitear el .env real (queda en el VPS, no en git).

# Dominio público del VPS (apunta un A record aquí, ej. wa.synaptechspa.cl → IP del VPS)
EVOLUTION_DOMAIN=wa.synaptechspa.cl

# Clave maestra de Evolution API. Genera una fuerte, ej: openssl rand -hex 32
# Esta MISMA clave se guarda como secret EVOLUTION_API_KEY en Firebase Functions.
EVOLUTION_API_KEY=CAMBIAME_openssl_rand_hex_32

# Password de Postgres (interno al VPS). Genera otra fuerte.
POSTGRES_PASSWORD=CAMBIAME_password_postgres_fuerte
