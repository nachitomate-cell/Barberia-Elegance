rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Fotos de perfil de clientes — cada usuario sube solo a su propio uid
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && isImage()
                   && isUnder5MB();
    }

    // Imágenes del chat público (/chat) — el cliente (sesión anónima) sube
    // solo a la carpeta de SU chat (userId == uid). Se comprimen client-side
    // antes de subir; el cap de 5MB es la red de seguridad.
    match /chat/{tenantId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && isImage()
                   && isUnder5MB();
    }

    // Fotos de perfil de barberos
    match /barberos/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Galería lookbook (elegance root)
    match /lookbook/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder10MB() && isImage();
    }

    // Productos (elegance root)
    match /productos/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Servicio Favorito (elegance root)
    match /servicioFavorito/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Servicios (elegance root)
    match /servicios/{servicioId}/{fileName} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Assets del local (logo, fondo, etc.)
    match /assets/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Imágenes de banners/campañas de Marketing (elegance root)
    match /marketing/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Rutas multi-tenant (ferraza, gitana, etc.)
    // Fotos de perfil de clientes del club — cada usuario sube solo a su propio uid
    match /tenants/{tenantId}/avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && isImage()
                   && isUnder5MB();
    }
    match /tenants/{tenantId}/barberos/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }
    match /tenants/{tenantId}/lookbook/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder10MB() && isImage();
    }
    match /tenants/{tenantId}/productos/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }
    match /tenants/{tenantId}/marketing/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }
    match /tenants/{tenantId}/servicioFavorito/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }
    match /tenants/{tenantId}/{fileName} {
      allow read: if fileName.matches('tv-bg\\..*');
      allow write: if isAuth() 
                   && fileName.matches('tv-bg\\..*') 
                   && request.resource.size < 100 * 1024 * 1024;
    }
    match /tenants/{tenantId}/publicidad_tv/{imageId} {
      allow read: if true;
      allow write: if isAuth() && isUnder10MB() && isImage();
    }
    match /tenants/{tenantId}/servicios/{servicioId}/{fileName} {
      allow read: if true;
      allow write: if isAuth() && isUnder5MB() && isImage();
    }

    // Bloquear cualquier otra ruta
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
