{
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/panel",
      "destination": "/panel/index.html"
    },
    {
      "source": "/panel/:path*",
      "destination": "/panel/index.html"
    },
    {
      "source": "/servicios",
      "destination": "/index.html"
    },
    {
      "source": "/agenda",
      "destination": "/agenda.html"
    },
    {
      "source": "/agenda/:id*",
      "destination": "/agenda.html"
    },
    {
      "source": "/admin/elegance",
      "destination": "/admin/index.html"
    },
    {
      "source": "/gestion-interna",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/agenda",
      "destination": "/gestion-interna/agenda/index.html"
    },
    {
      "source": "/gestion-interna/login",
      "destination": "/gestion-interna/login/index.html"
    },
    {
      "source": "/gestion-interna/login/:path*",
      "destination": "/gestion-interna/login/index.html"
    },
    {
      "source": "/gestion-interna/servicios",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/configuracion",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/clientes",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/clientes/:uid*",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/barberos",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/premios",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/lookbook",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/metricas",
      "destination": "/gestion-interna/metricas.html"
    },
    {
      "source": "/gestion-interna/elegance",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/ferraza",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/gitana",
      "destination": "/gestion-interna/index.html"
    },
    {
      "source": "/gestion-interna/seed-barberos-tool",
      "destination": "/gestion-interna/seed-barberos-tool.html"
    }
  ]
}
