    { "source": "/empieza",         "has": [{ "type": "host", "value": "bioo.cl" }], "destination": "/empieza.html" },
    { "source": "/demo",            "has": [{ "type": "host", "value": "bioo.cl" }], "destination": "/empieza.html" },
    { "source": "/contacto",        "has": [{ "type": "host", "value": "bioo.cl" }], "destination": "/empieza.html" },
    { "source": "/:user",       "has": [{ "type": "host", "value": "bioo.cl" }], "destination": "/links/u.html" },

    { "source": "/",            "has": [{ "type": "host", "value": "empieza.synaptechspa.cl" }], "destination": "/empieza.html" },
