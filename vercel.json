    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "empieza.synaptechspa.cl" }], "destination": "/logo.jpg" },

    { "source": "/",            "has": [{ "type": "host", "value": "crea.synaptechspa.cl" }], "destination": "/crea.html" },
    { "source": "/:path*",      "has": [{ "type": "host", "value": "crea.synaptechspa.cl" }], "destination": "/crea.html" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "crea.synaptechspa.cl" }], "destination": "/syn-192.png" },

    { "source": "/dashboard",              "destination": "/dashboard.html" },
    { "source": "/registro",               "destination": "/registro.html" },
    { "source": "/refiere",                "destination": "/refiere.html" },
    { "source": "/refiere/:code",          "destination": "/refiere.html?code=:code" },
    { "source": "/empieza",                "destination": "/empieza.html" },
    { "source": "/demo",                   "destination": "/empieza.html" },
    { "source": "/contacto",               "destination": "/empieza.html" },
    { "source": "/crea",                   "destination": "/crea.html" },
    { "source": "/agenda",                 "destination": "/agenda.html" },
    { "source": "/agenda/:path*",          "destination": "/agenda.html" },
    { "source": "/servicios",              "destination": "/index.html" },
    { "source": "/gestion-interna",        "destination": "/gestion-interna/index.html" },
    { "source": "/gestion-interna/:path*", "destination": "/gestion-interna/index.html" },
    { "source": "/catalogo",               "destination": "/catalogo.html" },
    { "source": "/membresia",              "destination": "/membresia.html" },
    { "source": "/chat-miembros",          "destination": "/chat-miembros.html" },
    { "source": "/admin-membresias",       "destination": "/admin-membresias.html" },
    { "source": "/kronnos",                "destination": "/kronnos.html" },
    { "source": "/kronnos-admin",          "destination": "/kronnos-admin.html" },
    { "source": "/chat",                    "destination": "/chat.html" },
    { "source": "/bio",                     "destination": "/bio.html" },
    { "source": "/sorteo",                  "destination": "/sorteo.html" },
    { "source": "/sorteo/:id",              "destination": "/sorteo.html?id=:id" },
    { "source": "/:slug",                  "destination": "/barbero.html" }
