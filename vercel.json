{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",         "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed","value": "/" }
      ]
    },
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        { "key": "Content-Type",           "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "bioo.cl" }],
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/firebase-config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/firebaseUtils.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sorteo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sorteo",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "deluxeperfumes.synaptechspa.cl" }],
      "destination": "/catalogo",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "kronnos.synaptechspa.cl" }],
      "destination": "/kronnos",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.kronnos.synaptechspa.cl" }],
      "destination": "/kronnos-admin",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "links.synaptechspa.cl" }],
      "destination": "https://bioo.cl/:path*",
      "permanent": true
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "bioo.cl" }],
      "destination": "/editor?view=admin",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/__/auth/:path*",     "destination": "https://barberia-elegance.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/:path*", "destination": "https://barberia-elegance.firebaseapp.com/__/firebase/:path*" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelopalma.synaptechspa.cl" }],        "destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelohairdressing.synaptechspa.cl" }], "destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelo-hairdressing.synaptechspa.cl" }],"destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalon.synaptechspa.cl" }],        "destination": "/aura.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalonmalegrooming.synaptech.cl" }], "destination": "/aura.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalonmalegrooming.synaptechspa.cl" }],"destination": "/aura.png" },
