{
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/panel",
      "destination": "/panel/index.html"
    },
    {
      "source": "/panel/:path*",
      "destination": "/panel/index.html"
    },
    {
      "source": "/servicios",
      "destination": "/index.html"
    },
    {
      "source": "/agenda",
      "destination": "/agenda.html"
    },
    {
      "source": "/agenda/:id*",
      "destination": "/agenda.html"
    },
    {
      "source": "/admin/elegance",
      "destination": "/admin/index.html"
    },
    {
      "source": "/gestion-interna/:path*",
      "destination": "/gestion-interna/index.html"
    }
  ]
}
