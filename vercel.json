{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",         "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed","value": "/" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/firebaseUtils.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "deluxeperfumes.synaptechspa.cl" }],
      "destination": "/catalogo",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelopalma.synaptechspa.cl" }],        "destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelohairdressing.synaptechspa.cl" }], "destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "marcelo-hairdressing.synaptechspa.cl" }],"destination": "/marcelo1.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalon.synaptechspa.cl" }],        "destination": "/aura.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalonmalegrooming.synaptech.cl" }], "destination": "/aura.png" },
    { "source": "/favicon.ico", "has": [{ "type": "host", "value": "aurasalonmalegrooming.synaptechspa.cl" }],"destination": "/aura.png" },
    { "source": "/favicon.ico",            "destination": "/logo.jpg" },
    { "source": "/dashboard",              "destination": "/dashboard.html" },
    { "source": "/registro",               "destination": "/registro.html" },
    { "source": "/agenda",                 "destination": "/agenda.html" },
    { "source": "/agenda/:path*",          "destination": "/agenda.html" },
    { "source": "/servicios",              "destination": "/index.html" },
    { "source": "/gestion-interna",        "destination": "/gestion-interna/index.html" },
    { "source": "/gestion-interna/:path*", "destination": "/gestion-interna/index.html" },
    { "source": "/catalogo",               "destination": "/catalogo.html" },
    { "source": "/membresia",              "destination": "/membresia.html" },
    { "source": "/chat-miembros",          "destination": "/chat-miembros.html" },
    { "source": "/admin-membresias",       "destination": "/admin-membresias.html" },
    { "source": "/:slug",                  "destination": "/barbero.html" }
  ]
}
