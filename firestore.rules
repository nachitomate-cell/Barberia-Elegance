rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    //  FUNCIONES AUXILIARES
    //
    //  Toda la lógica se basa en Custom Claims (JWT de Firebase Auth).
    //  Los claims son asignados por Cloud Functions y son inmutables
    //  desde el cliente — eliminan la necesidad de leer Firestore en
    //  cada evaluación de regla.
    //
    //  Estructura de claims esperada:
    //    { role: 'admin' | 'jefe' | 'barbero', tenantId: string }
    // ═══════════════════════════════════════════════════════════════

    function autenticado() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Lectura segura de claims con valor por defecto vacío
    function rol() {
      return request.auth.token.get('role', '');
    }

    function tenantClaim() {
      return request.auth.token.get('tenantId', '');
    }

    // ── Fallback de emergencia (bootstrap) ─────────────────────────
    function esBootstrap() {
      return autenticado()
          && request.auth.token.email in [
               'ignaciiio.mate@gmail.com',
               'barrazanicolasfabian@gmail.com'
             ];
    }

    // TEMP: fallback Firestore mientras los barberos no tengan Custom Claims.
    // Eliminar después de ejecutar migrarClaimsExistentes() y que todos
    // cierren sesión y vuelvan a abrir.
    function esBarberoFirestore(tid) {
      return autenticado() && (
        tid == 'elegance'
          ? exists(/databases/$(database)/documents/barberos/$(request.auth.uid))
          : exists(/databases/$(database)/documents/tenants/$(tid)/barberos/$(request.auth.uid))
      );
    }

    // ── Pertenencia a tenant ────────────────────────────────────────
    function esDeTenant(tid) {
      return autenticado() && tenantClaim() == tid;
    }

    // ── Superadmin marca Kronnos (Claudio) ──────────────────────────
    // Camino 1.5: Claudio administra los 4 tenants Kronnos (marca + 3 legacy)
    // pero un JWT solo puede tener un tenantId en claims. Este helper le da
    // acceso admin en los 4 sin comprometer aislamiento de otros tenants.
    function esKronnosBrandAdmin(tid) {
      return autenticado()
          && request.auth.token.email == 'administracionkronnos@gmail.com'
          && tid in ['kronnos', 'kronnos_penablanca', 'kronnos_limache', 'kronnos_woman'];
    }

    // ── Roles ───────────────────────────────────────────────────────
    function esStaff(tid) {
      return (esDeTenant(tid) && rol() in ['admin', 'jefe', 'barbero'])
          || esBootstrap()
          || esKronnosBrandAdmin(tid)
          || esBarberoFirestore(tid); // TEMP: eliminar post-migración
    }

    function esAdmin(tid) {
      return (esDeTenant(tid) && rol() in ['admin', 'jefe'])
          || esBootstrap()
          || esKronnosBrandAdmin(tid);
    }

    function esAdminEstricto(tid) {
      return (esDeTenant(tid) && rol() == 'admin')
          || esBootstrap()
          || esKronnosBrandAdmin(tid);
    }

    // ── Verificar si el usuario es el cliente de un documento de cita ──
    function esCliente(data) {
      return autenticado()
          && (data.get('clienteEmail', '').lower() == request.auth.token.email
              || data.get('clienteUid',  '') == request.auth.uid
              || data.get('clienteId',   '') == request.auth.uid);
    }

    // ── Validación de campos ────────────────────────────────────────

    // Verifica que un campo NO fue modificado en un update
    function sinCambio(campo) {
      return !(campo in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Booking público válido: campos mínimos + estado inicial correcto
    // + no inyecta campos de privilegio
    function bookingPublicoValido() {
      return request.resource.data.keys().hasAll(['fecha', 'hora', 'clienteNombre', 'estado'])
          && request.resource.data.estado in ['Confirmada', 'Confirmado', 'Pendiente']
          && !request.resource.data.keys().hasAny(['rol', 'role', 'tenantId', 'adminOverride', 'barberoRol']);
    }

    // ═══════════════════════════════════════════════════════════════
    //  _system — configuración global (versionamiento, kill switch)
    //  Lectura pública: solo contiene metadata no sensible (versión
    //  de app y estado del tenant). Los listeners de TenantContext y
    //  VersionManager deben funcionar antes del login y tras logout.
    //  Escritura solo para bootstrap (SynapTech).
    // ═══════════════════════════════════════════════════════════════
    match /_system/{docId} {
      allow read:  if true;
      allow write: if esBootstrap();
    }

    // ═══════════════════════════════════════════════════════════════
    //  _billing — estado de pagos por tenant
    //  Lectura solo para staff del tenant. Escritura solo bootstrap.
    // ═══════════════════════════════════════════════════════════════
    match /_billing/{tid} {
      allow read:  if esStaff(tid) || esBootstrap();
      allow write: if esBootstrap();
    }

    // ═══════════════════════════════════════════════════════════════
    //  _ingresos — snapshot mensual de ingresos proyectados
    //  Se escribe desde /admin cada vez que se recalcula el widget.
    //  Solo SynapTech (bootstrap) puede leer y escribir.
    // ═══════════════════════════════════════════════════════════════
    match /_ingresos/{mesId} {
      allow read, write: if esBootstrap();
    }

    // ═══════════════════════════════════════════════════════════════
    //  _referrals — programa de referidos B2B (SaaS growth loop)
    //
    //  Modelo:
    //    _referrals/{tenantId}        — counter + código por tenant
    //    _referralCodes/{CODE}        — índice inverso CODE → tenant
    //                                   (lectura pública, para landing)
    //    _referralSignups/{signupId}  — prospecto que llegó vía un código
    //
    //  Toda escritura se hace vía Cloud Functions (esBootstrap incluido
    //  cuando una CF corre con admin SDK). Lectura limitada al staff del
    //  tenant referidor (su propio panel) o al super-admin global.
    // ═══════════════════════════════════════════════════════════════
    match /_referrals/{tid} {
      allow read:  if esAdmin(tid) || esBootstrap();
      allow write: if esBootstrap();

      // Subcolección: referidos que este tenant trajo, con estado y meses gratis.
      // Gestionada 100% desde /admin (superadmin) por ahora — cuando el panel
      // interno del tenant lo exponga, se puede aflojar a esAdmin(tid) en read.
      match /referidos/{referredTid} {
        allow read, write: if esBootstrap();
      }
    }
    match /_referralCodes/{code} {
      // Lectura pública: la landing /refiere/{code} la usa SIN sesión
      // para mostrar "te invita @{tenantName}". Solo expone tenantId +
      // tenantName + active — no hay PII.
      allow read:  if true;
      allow write: if esBootstrap();
    }
    match /_referralSignups/{signupId} {
      // El staff del tenant referidor ve sus propios signups; el super-
      // admin los ve todos. Las escrituras pasan por Cloud Functions.
      allow read:  if esBootstrap()
                   || (autenticado() && resource.data.get('referrerTenantId', '') == tenantClaim()
                                      && rol() in ['admin', 'jefe']);
      allow write: if esBootstrap();
    }

    // ═══════════════════════════════════════════════════════════════
    //  _synaptechLeads — captura de leads inbound (landing pública
    //  synaptechspa.cl/empieza, sin código de referido).
    //  Solo super-admin lee. Escrituras vía Cloud Function callable.
    // ═══════════════════════════════════════════════════════════════
    match /_synaptechLeads/{leadId} {
      allow read:  if esBootstrap();
      allow write: if esBootstrap();
    }

    // ═══════════════════════════════════════════════════════════════
    //  ELEGANCE — colecciones raíz (tenant legacy/predeterminado)
    // ═══════════════════════════════════════════════════════════════

    // ── /barberos ──────────────────────────────────────────────────
    // Lectura pública: widget de reservas y agenda pública necesitan
    // listar barberos y su configuración (subcolección /configuracion).
    match /barberos/{barberoId} {
      allow read: if true;
      allow create: if esAdmin('elegance')
                    // Un barbero puede crear su propio doc de enlace (UID → mainDocId).
                    // Condiciones: doc ID == su UID, referencia un doc principal real
                    // (que no sea a su vez un enlace), y declara rol 'barbero'.
                    // Rompe el chicken-and-egg de esBarberoFirestore sin custom claims.
                    || (autenticado()
                        && uid() == barberoId
                        && request.resource.data.get('uid', '') == uid()
                        && request.resource.data.get('rol', '') == 'barbero'
                        && '_mainDocId' in request.resource.data
                        && request.resource.data._mainDocId != barberoId
                        && exists(/databases/$(database)/documents/barberos/$(request.resource.data._mainDocId))
                        && !('_mainDocId' in get(/databases/$(database)/documents/barberos/$(request.resource.data._mainDocId)).data));
      allow update: if esAdmin('elegance')
                    || (esStaff('elegance')
                        // Barbero se autoedita: el docId puede ser su propio UID
                        // (patrón legacy) o el doc puede referenciar su UID vía
                        // authUid (patrón nuevo — evita migrar docIds existentes).
                        && (uid() == barberoId
                            || uid() == resource.data.get('authUid', ''))
                        && sinCambio('rol')
                        && sinCambio('disponible')
                        && sinCambio('comision'));
      allow delete: if esAdminEstricto('elegance');

      // Subcolecciones: configuración de horario, preferencias, etc.
      // Lectura pública para que la agenda y el widget de reservas funcionen.
      match /{subCol}/{docId} {
        allow read: if true;
        allow write: if esStaff('elegance');
      }

      // Link in Bio: la página pública (sin auth) incrementa SOLO views/clicks.
      match /settings/linkbio {
        allow update: if resource != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'clicks']);
      }
    }

    // ── /citas ─────────────────────────────────────────────────────
    // Creación pública sin auth (widget de reservas online) con
    // validación estricta de estructura.  Staff puede crear/editar.
    // Clientes pueden leer y cancelar sus propias citas (por email o uid).
    match /citas/{citaId} {
      allow read: if esStaff('elegance') || esCliente(resource.data);
      allow create: if bookingPublicoValido()
                    || esStaff('elegance');
      allow update: if esStaff('elegance')
                    || (esCliente(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                        && request.resource.data.estado == 'Cancelada')
                    || (esCliente(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingGoogleReview'])
                        && request.resource.data.pendingGoogleReview == false)
                    || (esCliente(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedbackPrivadoRating', 'feedbackPrivadoComment', 'feedbackPrivadoCreatedAt']));
      allow delete: if esStaff('elegance');
    }

    // ── /servicios ─────────────────────────────────────────────────
    match /servicios/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /bloqueos ──────────────────────────────────────────────────
    match /bloqueos/{docId} {
      allow read: if true;
      allow write: if esStaff('elegance');
    }

    // ── /premios ───────────────────────────────────────────────────
    match /premios/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /redemptions ───────────────────────────────────────────────
    // Canjes efímeros generados por el cliente (QR/PIN 15 min).
    // El cliente solo puede crear con su uid, status=pending y validando
    // que tiene saldo. Puede cancelar los suyos mientras estén pendientes.
    // Staff/admin: lectura y escritura completa (aprueba el canje).
    match /redemptions/{docId} {
      allow read: if autenticado() && (
        resource.data.userId == uid() || esStaff('elegance')
      );
      allow create: if autenticado()
                    && request.resource.data.userId == uid()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.token is string
                    && request.resource.data.costoSellos is number
                    && request.resource.data.costoSellos > 0
                    // Backward-compat: leemos `sellosDisponibles` con fallback a `stamps`
                    // (users legacy / migrados desde AgendaPro tienen solo `stamps`).
                    && get(/databases/$(database)/documents/users/$(uid())).data
                         .get('sellosDisponibles',
                              get(/databases/$(database)/documents/users/$(uid())).data.get('stamps', 0))
                       >= request.resource.data.costoSellos;
      allow update: if autenticado() && (
        // Cliente cancela lo suyo (solo pending → cancelled)
        (resource.data.userId == uid()
         && resource.data.status == 'pending'
         && request.resource.data.status == 'cancelled'
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']))
        || esStaff('elegance')
      );
      allow delete: if esAdmin('elegance');
    }

    // ── /productos ─────────────────────────────────────────────────
    match /productos/{docId} {
      allow read: if true;
      allow create, delete: if esAdmin('elegance');
      // Staff (incl. barbero) solo puede modificar el stock al vender.
      // Admin mantiene control de precio, nombre y demás campos.
      allow update: if esAdmin('elegance')
                    || (esStaff('elegance')
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
    }

    // ── /referral_awards ───────────────────────────────────────────
    // Audit log del programa de referidos B2C: la CF referidos-recompensa
    // escribe un doc por cada recompensa otorgada. Solo admin lo consulta
    // desde el tab "Boca a boca" de Fidelización. Escritura solo vía CF
    // (Admin SDK bypasea rules), por eso el cliente no puede write.
    match /referral_awards/{docId} {
      allow read: if esAdmin('elegance');
      allow write: if false;
    }

    // ── /review_intents (Google reviews · tracking de intención) ───
    // Espejo del path tenants/{tid}/review_intents (elegance vive en root).
    match /review_intents/{docId} {
      allow read: if true;
      allow create: if esAdmin('elegance');
      allow update: if resource.data.status == 'pending'
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'status', 'rating', 'ratedAt', 'redirectedToGoogleAt',
                         'feedbackText', 'landingOpenedAt',
                       ])
                    && request.resource.data.status in ['positive_redirected', 'negative_feedback', 'pending'];
      allow delete: if esAdmin('elegance');
    }

    // ── /giftCards ─────────────────────────────────────────────────
    // Lectura PÚBLICA: la página /saldo-gift-card consulta sin auth
    // con query where('codigo','==',code). El campo "codigo" actúa
    // como secreto compartido (impreso/QR). Trade-off conocido: una
    // query sin restricción podría exponer toda la colección — si se
    // necesita endurecer, migrar la consulta a Cloud Function pública
    // y restringir `read` a esStaff('elegance').
    // Escritura: staff crea y canjea (modifica saldo); solo admin borra.
    match /giftCards/{docId} {
      allow read:   if true;
      allow create: if esStaff('elegance');
      allow update: if esStaff('elegance');
      allow delete: if esAdmin('elegance');
    }

    // ── /sorteos ───────────────────────────────────────────────────
    // Versión root del tenant legacy `elegance`. Mismo contrato que la
    // sección multi-tenant (`/tenants/{tid}/sorteos`):
    //   · Lectura: PÚBLICA. La página /sorteo/:id (visitante sin sesión)
    //     necesita leer el sorteo para mostrar nombre/premio/fechas.
    //     No contiene PII — los participantes están en subcolección
    //     separada con read restringido.
    //   · Create + delete: solo admins.
    //   · Update: admins libre; público SOLO puede incrementar
    //     participantes_count en exactamente +1 (sin tocar otro campo).
    //   · Subcolección /participantes: create público con validaciones
    //     mínimas anti-abuse; read/update/delete reservado a admins (PII).
    match /sorteos/{sorteoId} {
      allow read:           if true;
      allow create, delete: if esAdmin('elegance');
      allow update: if esAdmin('elegance')
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantes_count'])
                        && request.resource.data.participantes_count is int
                        && request.resource.data.participantes_count == resource.data.get('participantes_count', 0) + 1);

      match /participantes/{participanteId} {
        allow read, update, delete: if esAdmin('elegance');
        // `pronostico` es opcional — solo lo envían los sorteos tipo FUTBOL
        // (marcador { local, visita } con enteros 0-20 para evitar spam).
        allow create: if request.resource.data.keys().hasOnly(['nombre', 'telefono', 'email', 'createdAt', 'pronostico'])
                      && request.resource.data.nombre is string
                      && request.resource.data.nombre.size() > 0
                      && request.resource.data.nombre.size() <= 80
                      && (!('telefono' in request.resource.data)
                          || (request.resource.data.telefono is string
                              && request.resource.data.telefono.size() <= 30))
                      && (!('email' in request.resource.data)
                          || (request.resource.data.email is string
                              && request.resource.data.email.size() <= 120))
                      && (!('pronostico' in request.resource.data)
                          || (request.resource.data.pronostico is map
                              && request.resource.data.pronostico.local is int
                              && request.resource.data.pronostico.local >= 0
                              && request.resource.data.pronostico.local <= 20
                              && request.resource.data.pronostico.visita is int
                              && request.resource.data.pronostico.visita >= 0
                              && request.resource.data.pronostico.visita <= 20));
      }
    }

    // ── /lookbook ──────────────────────────────────────────────────
    match /lookbook/{docId} {
      allow read: if true;
      allow create, delete: if esStaff('elegance');
      allow update: if esStaff('elegance')
        || (autenticado() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
    }

    // ── /settings ──────────────────────────────────────────────────
    // Configuración del local: pública para lectura (nombre, dirección,
    // teléfono, horario — se muestran en la página de reservas pública).
    match /settings/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }
    // Link in Bio (tenant elegance): incremento público de SOLO views/clicks.
    match /settings/linkbio {
      allow update: if resource != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'clicks']);
    }

    // ── /bio_leads — captura de leads del Link in Bio (todos los tenants) ──
    // Creación pública validada (formulario sin auth); lectura solo del staff
    // del tenant dueño. Guarda PII, por eso NO es de lectura pública.
    match /bio_leads/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['nombre', 'email', 'telefono', 'tenantId', 'origen', 'createdAt'])
                    && request.resource.data.origen == 'linkbio'
                    && request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() < 40;
      allow read, update, delete: if esBootstrap() || esStaff(resource.data.tenantId);
    }

    // ── /bios — Link in bio self-serve (SynapTech Links) ───────────
    // Páginas de usuarios SIN local. doc id = username (único por colisión
    // natural del id). Lectura pública (es una página pública). Escritura
    // solo del dueño (uid). Excepción: cualquiera puede incrementar los
    // contadores de analítica (`views` de la página y `clicks` por enlace).
    match /bios/{username} {
      allow read: if true;
      // Anónimo puede crear su propia bio (viralidad-first). Bloqueamos flags
      // de monetización (proRemoveWatermark, proCustomDomain) en el create
      // del cliente — esos los setea solo el webhook MP/Stripe via Admin SDK.
      allow create: if autenticado()
                    && request.resource.data.uid == uid()
                    && request.resource.data.username is string
                    && !request.resource.data.keys().hasAny(['proRemoveWatermark', 'proCustomDomain', 'verified'])
                    && !exists(/databases/$(database)/documents/bio_handles/$(username));
      // Update del dueño: NO puede tocar flags Pro (cierre del loophole de
      // quitarse la marca de agua editando directo en Firestore).
      allow update: if (autenticado() && resource.data.uid == uid()
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['proRemoveWatermark', 'proCustomDomain', 'verified']))
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'clicks']);
      allow delete: if autenticado() && resource.data.uid == uid();

      // ── /bios/{username}/leads — captura de correos (newsletter) ──
      // Cualquier visitante puede suscribirse (crear su lead, doc id = email,
      // con email válido y solo los campos permitidos). Solo el dueño del
      // perfil puede leer o borrar los leads. No se permite editar.
      match /leads/{leadId} {
        allow create: if request.resource.data.email is string
                      && request.resource.data.email.size() > 3
                      && request.resource.data.email.size() < 254
                      && request.resource.data.keys().hasOnly(['email', 'blockId', 'ts']);
        allow read, delete: if autenticado()
                      && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow update: if false;
      }

      // ── /bios/{username}/secrets — datos privados (hiddenUrl de paywalls) ──
      // Acceso ESTRICTAMENTE limitado al dueño del perfil (bios.uid). El público
      // tiene denegada toda lectura/escritura: aquí vive la propiedad intelectual
      // (URLs de descarga, archivos, grupos privados) que el comprador solo recibe
      // tras verificar el pago en el backend.
      match /secrets/{secretId} {
        allow read, delete: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow create, update: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid()
                    && request.resource.data.uid == uid();
      }

      // ── /bios/{username}/purchases — historial de ventas del paywall ──
      // Lectura SOLO del dueño (su panel de ventas). La escritura está reservada
      // al Admin SDK (webhook/verifyUnlock), que ignora estas reglas: aquí
      // cualquier cliente tiene la escritura denegada.
      match /purchases/{purchaseId} {
        allow read: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow write: if false;
      }

      // ── /bios/{username}/blockStats — analítica por bloque ──
      // Solo el dueño lee sus estadísticas. La escritura es exclusiva del
      // Cloud Function biooTrackClick (admin SDK), que valida la bio y
      // hace rate-limiting en memoria. Cliente nunca escribe acá.
      match /blockStats/{blockId} {
        allow read: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow write: if false;
      }

      // ── /bios/{username}/reservasConfig — agenda gratuita del creador ──
      // Config pública (servicios, horario semanal, bloqueos): el flujo de
      // reserva del visitante necesita LEERLA para mostrar horas disponibles.
      // Escritura solo del dueño (mismo uid del doc /bios).
      match /reservasConfig/{cfgId} {
        allow read: if true;
        allow write: if autenticado()
                     && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid()
                     && request.resource.data.uid == uid();
      }

      // ── /bios/{username}/reservas — citas tomadas por clientes ──
      // El dueño tiene acceso total (gestión). El visitante anónimo SOLO puede
      // CREAR su propia reserva con un schema estricto (no puede leer ni
      // editar — su WhatsApp/nombre quedan privados para el barbero).
      match /reservas/{reservaId} {
        allow read: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow update, delete: if autenticado()
                    && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
        allow create: if request.resource.data.keys().hasOnly([
                        'servicioId','servicioNombre','duracion','precio',
                        'fecha','hora','slotKey','cliente','estado','creadaEn',
                      ])
                      && request.resource.data.fecha is string
                      && request.resource.data.fecha.size() == 10
                      && request.resource.data.hora is string
                      && request.resource.data.hora.size() == 5
                      && request.resource.data.duracion is int
                      && request.resource.data.duracion >= 5
                      && request.resource.data.duracion <= 480
                      && request.resource.data.estado == 'confirmada'
                      && request.resource.data.cliente.nombre is string
                      && request.resource.data.cliente.nombre.size() > 0
                      && request.resource.data.cliente.nombre.size() <= 80
                      && request.resource.data.cliente.whatsapp is string
                      && request.resource.data.cliente.whatsapp.size() >= 8
                      && request.resource.data.cliente.whatsapp.size() <= 20
                      // email es opcional (compat con reservas viejas). Cuando se
                      // envía, validamos tipo y largo razonable para evitar abuso
                      // (la CF lo usa para mandar confirmación + recordatorio 24h).
                      && (!('email' in request.resource.data.cliente)
                          || (request.resource.data.cliente.email is string
                              && request.resource.data.cliente.email.size() <= 120));
      }

      // ── /bios/{username}/disponibilidad — espejo público de slots ocupados ──
      // Doc por fecha (id = "YYYY-MM-DD") con la lista de slots tomados (sin
      // PII). Lo lee el flujo de reserva del visitante para mostrar horas
      // libres; lo actualiza la transacción de creación de reserva.
      // Validación: solo se PUEDE AGREGAR (size +1) → evita borrados arbitrarios.
      // El dueño tiene acceso total para gestionar / cancelar.
      match /disponibilidad/{fecha} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['ocupados','updatedAt'])
                      && request.resource.data.ocupados is list
                      && request.resource.data.ocupados.size() <= 50;
        allow update: if request.resource.data.keys().hasOnly(['ocupados','updatedAt'])
                      && request.resource.data.ocupados is list
                      && request.resource.data.ocupados.size() <= 50
                      && request.resource.data.ocupados.size() == resource.data.ocupados.size() + 1;
        allow write: if autenticado()
                     && get(/databases/$(database)/documents/bios/$(username)).data.uid == uid();
      }

      // ── /bios/{username}/reservasMeta — métricas del free tier ──
      // Único doc 'contadores' con { mesActual, usadasMes, totalHistorico }.
      // Sin PII: la UI lo lee sin auth para mostrar la barra de uso. Solo
      // el Admin SDK (Cloud Function avisarNuevaReservaBioo) lo escribe.
      match /reservasMeta/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── /bio_users — mapeo uid → username (privado del dueño) ──────
    match /bio_users/{userId} {
      allow read, write: if autenticado() && uid() == userId;

      // platform_orders — historial de cobros que SynapTech le hizo al creador
      // (productos premium tipo "Quitar marca de agua"). El creador puede leer
      // sus órdenes; toda escritura va por Admin SDK (Cloud Functions) para
      // que el cliente no pueda autotorgarse grants.
      match /platform_orders/{orderId} {
        allow read:  if autenticado() && uid() == userId;
        allow write: if false;
      }
    }

    // ── /bio_mp — tokens OAuth de Mercado Pago del creador (marketplace) ──
    // Credenciales bearer de la cuenta MP del creador (access/refresh token).
    // Acceso EXCLUSIVO del Admin SDK (Cloud Functions): el cliente tiene
    // denegada toda lectura/escritura para que el token nunca salga al browser.
    match /bio_mp/{userId} {
      allow read, write: if false;
    }

    // ── /tenant_mp — tokens OAuth de Mercado Pago de la barbería (tenant) ──
    // Igual que bio_mp pero por tenant. CERRADO al cliente: solo el Admin SDK
    // (Cloud Functions) lee/escribe. El estado público "conectado/no" vive en
    // _system/mercadopago_{tid} (no sensible), que el panel sí puede leer.
    match /tenant_mp/{tid} {
      allow read, write: if false;
    }

    // ── /bio_handles — alias bioo.cl/<handle> → tenant (bio de locales) ──
    // Mapea un handle público a un tenant para servir su Link in Bio en
    // bioo.cl sin redirect. Lectura pública (la usa el edge middleware sin
    // auth). Escritura solo del staff del tenant dueño; no se puede tomar un
    // handle ya usado como usuario self-serve (colisión con /bios).
    match /bio_handles/{handle} {
      allow read: if true;
      allow create: if esStaff(request.resource.data.tenantId)
                    && request.resource.data.tenantId is string
                    && !exists(/databases/$(database)/documents/bios/$(handle));
      allow update, delete: if esStaff(resource.data.tenantId);
    }

    // ── /bio_claims — tokens de reclamo de bios prellenados (privado) ──
    // Los crea biooProvision (Admin SDK) y los consume biooClaim (Admin SDK).
    // Ningún cliente debe leerlos ni escribirlos: el token autoriza la toma de
    // propiedad de un bio, así que se mantiene fuera del alcance del cliente.
    match /bio_claims/{token} {
      allow read, write: if false;
    }

    // ── /bio_email_owners — índice privado email → handle (idempotencia + ──
    // adopción por email). Solo Admin SDK (biooProvision/biooClaim).
    match /bio_email_owners/{email} {
      allow read, write: if false;
    }

    // ── /bio_reports — reportes de bios (anti-abuse) ──────────────────────
    // Cualquier visitante (incluso sin auth) puede reportar una bio desde el
    // footer "Reportar". Lectura/moderación queda restringida a bootstrap
    // (SynapTech). Sin update/delete públicos para que ningún spammer pueda
    // borrar reportes propios. Validamos un set acotado de campos para evitar
    // que se use como un "buzón anónimo" para data arbitraria.
    match /bio_reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly(['username', 'reason', 'ua', 'ref', 'createdAt'])
                    && request.resource.data.username is string
                    && request.resource.data.username.size() < 40
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() < 300;
      allow read:   if esBootstrap();
      allow update, delete: if esBootstrap();
    }

    // ── /gastos ────────────────────────────────────────────────────
    // Datos financieros: acceso exclusivo a admin/jefe.
    match /gastos/{docId} {
      allow read, write: if esAdmin('elegance');
    }

    // ── /listaEspera (lista de espera del panel) ───────────────────
    // Solo staff la gestiona; el dashboard (Inicio) la lee para el KPI.
    match /listaEspera/{docId} {
      allow read, write: if esStaff('elegance');
    }

    // ── /_stats (resumen agregado por Cloud Function) ──────────────
    // Lo escribe la CF stats-aggregate (admin SDK); el panel solo lee.
    match /_stats/{docId} {
      allow read:  if esStaff('elegance');
      allow write: if false;
    }

    // ── /config ────────────────────────────────────────────────────
    // Configuración UI (activa productos, etc.).
    match /config/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /configuracion ─────────────────────────────────────────────
    // Horario y configuración operativa del local. El widget de reservas
    // la lee para calcular disponibilidad sin necesitar autenticación.
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /system_errors ─────────────────────────────────────────────
    // El error-logger del cliente escribe aquí para observabilidad.
    match /system_errors/{docId} {
      allow write: if true;
      allow read:  if esBootstrap();
    }

    // ── /notification_logs ─────────────────────────────────────────
    // Auditoría global de push/email/WhatsApp. Lo escriben las Cloud
    // Functions (admin SDK, ignora reglas). Solo el superadmin lo lee
    // desde el portal /admin.
    match /notification_logs/{docId} {
      allow read:  if esBootstrap();
      allow write: if false;
    }

    // ── /broadcast_campaigns ───────────────────────────────────────
    // Campañas de push masiva al panel (gestion-interna + agenda.html).
    // Las crea y escribe la Cloud Function broadcastAnuncio (admin SDK).
    // Solo el superadmin las lee desde /admin, junto con la sub-colección
    // recipients que registra a quién le llegó cada notificación.
    match /broadcast_campaigns/{campaignId} {
      allow read:  if esBootstrap();
      allow write: if false;
      match /recipients/{recipientId} {
        allow read:  if esBootstrap();
        allow write: if false;
      }
    }

    // ── /servicioFavorito ──────────────────────────────────────────
    // Foto personalizada por cliente. Staff asigna; cliente lee/sube la suya.
    match /servicioFavorito/{docId} {
      allow read:   if autenticado() && (
                       resource.data.email == request.auth.token.email
                    || esStaff('elegance')
                    );
      allow create: if esStaff('elegance')
                    || (autenticado()
                        && request.resource.data.email == request.auth.token.email);
      allow update: if esStaff('elegance')
                    || (autenticado()
                        && resource.data.email == request.auth.token.email);
      allow delete: if esStaff('elegance');
    }

    // ── /clientes ──────────────────────────────────────────────────
    // Staff lee/escribe todo. Clientes autenticados pueden crear/actualizar
    // su propio documento (identificado por uid en el campo uid).
    match /clientes/{docId} {
      allow read:   if esStaff('elegance');
      allow create: if esStaff('elegance')
                    || (autenticado()
                        && request.resource.data.uid == request.auth.uid
                        && !request.resource.data.keys().hasAny(['role', 'adminOverride']));
      allow update: if esStaff('elegance')
                    || (autenticado()
                        && (resource.data.get('uid', '') == request.auth.uid
                            || resource.data.get('uid', null) == null
                            || resource.data.get('uid', '') == '')
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'adminOverride']));
      allow delete: if esAdmin('elegance');
    }

    // ── /users ─────────────────────────────────────────────────────
    // Un cliente accede solo a su propio doc.
    // Staff puede leer todos; nadie puede modificar role/tenantId/rol.
    match /users/{userId} {
      allow read: if autenticado() && (uid() == userId || esStaff('elegance'));
      allow create: if autenticado()
                    && uid() == userId
                    && !request.resource.data.keys().hasAny(['role', 'tenantId', 'rol', 'adminOverride']);
      allow update: if autenticado()
                    && (uid() == userId || esStaff('elegance'))
                    && sinCambio('role')
                    && sinCambio('tenantId')
                    && sinCambio('rol');
      allow delete: if esAdmin('elegance');
    }

    // ── /userPublic ────────────────────────────────────────────────
    // Perfil PÚBLICO para "comparar con un amigo": solo campos no
    // sensibles (nombre, sellos históricos, foto). Cada quien escribe
    // el suyo (id == su uid); cualquier miembro autenticado puede leer.
    match /userPublic/{userId} {
      allow read:  if autenticado();
      allow write: if autenticado() && (uid() == userId || esStaff('elegance'));
    }

    // ── /resenas ───────────────────────────────────────────────────
    // Creadas desde el ReviewModal al completar una cita.
    // Staff lee para analytics; cualquier staff puede escribir.
    match /resenas/{docId} {
      allow read:  if esStaff('elegance');
      allow write: if esStaff('elegance');
    }

    // ── /admin_notes ───────────────────────────────────────────────
    match /admin_notes/{docId} {
      allow read, write: if esStaff('elegance');
    }

    // ── /fcm_tokens ────────────────────────────────────────────────
    // Cualquier usuario autenticado puede registrar su token push.
    match /fcm_tokens/{tokenId} {
      allow read: if esStaff('elegance');
      allow write: if autenticado();
    }

    // ── /barber_settings (legacy) ───────────────────────────────────
    match /barber_settings/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /soporte_mensajes ──────────────────────────────────────────
    // Mensajes de soporte enviados por admins de elegance a SynapTech.
    // Escritura: admins del local. Lectura y marcar leído: bootstrap.
    match /soporte_mensajes/{docId} {
      allow read:   if esAdmin('elegance') || esBootstrap();
      allow create: if esAdmin('elegance');
      allow update: if esBootstrap();
      allow delete: if esBootstrap();
    }

    // ── /publicidad_tv ─────────────────────────────────────────────
    match /publicidad_tv/{docId} {
      allow read: if true;
      allow write: if esStaff('elegance');
    }
    
    // ── Academia ───────────────────────────────────────────────────
    match /cursos_academia/{docId} {
      allow read, write: if esStaff('elegance');
    }
    match /alumnos_academia/{docId} {
      allow read, write: if esStaff('elegance');
    }
    match /material_academia/{docId} {
      allow read, write: if esStaff('elegance');
    }

    // ── /caja_sesiones ─────────────────────────────────────────────
    // Sesiones de caja (apertura/cierre). Solo staff del local.
    match /caja_sesiones/{docId} {
      allow read, write: if esStaff('elegance');
    }

    // ── /slotLocks ─────────────────────────────────────────────────
    // Fuente pública de ocupación para el widget de reservas (sin auth).
    // Los documentos incluyen fecha/hora/barberoId/duracion para que
    // el widget pueda filtrar sin leer citas (que requieren auth).
    match /slotLocks/{lockId} {
      allow read:   if true;
      allow create: if esStaff('elegance')
                    || request.resource.data.keys().hasOnly(['citaId', 'creadoEn', 'fecha', 'hora', 'barberoId', 'duracion']);
      allow update: if esStaff('elegance');
      allow delete: if esStaff('elegance');
    }

    // ── /product_reservations ──────────────────────────────────────
    // Cliente crea su propia reserva (status='pending').
    // Staff puede crear ventas directas (status='delivered') desde el panel
    // (Venta Rápida en Productos o Productos del Ticket en Agenda) y
    // actualizar el estado o cualquier campo de la reserva.
    match /product_reservations/{docId} {
      allow read:   if autenticado() && (resource.data.get('userId', '') == uid() || esStaff('elegance'));
      allow create: if esStaff('elegance')
                    || (autenticado()
                        && request.resource.data.userId == uid()
                        && request.resource.data.status == 'pending'
                        && !request.resource.data.keys().hasAny(['role', 'tenantId', 'adminOverride']));
      allow update: if esStaff('elegance');
      allow delete: if esAdmin('elegance');
    }

    // ── /chatbot — config del bot del chat público (Elegance).
    // Read público (lo lee el chat anónimo); write solo admin.
    match /chatbot/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /chats ─────────────────────────────────────────────────────
    // El cliente lee/escribe solo su propio chat. Staff lee/escribe todos.
    match /chats/{userId} {
      allow read, write: if autenticado() && (uid() == userId || esStaff('elegance'));

      match /messages/{msgId} {
        allow read:          if autenticado() && (uid() == userId || esStaff('elegance'));
        allow create:        if autenticado() && (uid() == userId || esStaff('elegance'));
        allow update, delete: if esAdmin('elegance');
      }
    }

    // ═══════════════════════════════════════════════════════════════
    //  MULTI-TENANT — /tenants/{tid}/...
    //  El tenantId del usuario (claim) debe coincidir con {tid}.
    // ═══════════════════════════════════════════════════════════════

    match /tenants/{tid} {
      allow read: if true;
      allow write: if esAdmin(tid);

      // ── barberos ─────────────────────────────────────────────────
      match /barberos/{barberoId} {
        allow read: if true;
        allow create: if esAdmin(tid)
                      || (autenticado()
                          && uid() == barberoId
                          && request.resource.data.get('uid', '') == uid()
                          && request.resource.data.get('rol', '') == 'barbero'
                          && '_mainDocId' in request.resource.data
                          && request.resource.data._mainDocId != barberoId
                          && exists(/databases/$(database)/documents/tenants/$(tid)/barberos/$(request.resource.data._mainDocId))
                          && !('_mainDocId' in get(/databases/$(database)/documents/tenants/$(tid)/barberos/$(request.resource.data._mainDocId)).data));
        allow update: if esAdmin(tid)
                      || (esStaff(tid)
                          // Barbero se autoedita: docId == su UID (legacy)
                          // o el doc apunta a su UID vía authUid (nuevo).
                          && (uid() == barberoId
                              || uid() == resource.data.get('authUid', ''))
                          && sinCambio('rol')
                          && sinCambio('disponible')
                          && sinCambio('comision'));
        allow delete: if esAdminEstricto(tid);

        match /{subCol}/{docId} {
          allow read: if true;
          allow write: if esStaff(tid);
        }
      }

      // ── citas (panel admin) ───────────────────────────────────────
      match /citas/{citaId} {
        allow read: if esStaff(tid) || esCliente(resource.data);
        allow create: if bookingPublicoValido() || esStaff(tid);
        allow update: if esStaff(tid)
                      || (esCliente(resource.data)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                          && request.resource.data.estado == 'Cancelada')
                      || (esCliente(resource.data)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingGoogleReview'])
                          && request.resource.data.pendingGoogleReview == false)
                      || (esCliente(resource.data)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedbackPrivadoRating', 'feedbackPrivadoComment', 'feedbackPrivadoCreatedAt']));
        allow delete: if esStaff(tid);
      }

      // ── bookings (flujo público web) ──────────────────────────────
      match /bookings/{bookingId} {
        allow read: if esStaff(tid) || esCliente(resource.data);
        allow create: if bookingPublicoValido() || esStaff(tid);
        allow update: if esStaff(tid)
                      || (esCliente(resource.data)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                          && request.resource.data.estado == 'Cancelada');
        allow delete: if esAdmin(tid);
      }

      // ── servicios ─────────────────────────────────────────────────
      match /servicios/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── bloqueos ──────────────────────────────────────────────────
      match /bloqueos/{docId} {
        allow read: if true;
        allow write: if esStaff(tid);
      }

      // ── premios ───────────────────────────────────────────────────
      match /premios/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── redemptions (canjes efímeros con QR/PIN) ─────────────────
      match /redemptions/{docId} {
        allow read: if autenticado() && (
          resource.data.userId == uid() || esStaff(tid)
        );
        allow create: if autenticado()
                      && request.resource.data.userId == uid()
                      && request.resource.data.status == 'pending'
                      && request.resource.data.token is string
                      && request.resource.data.costoSellos is number
                      && request.resource.data.costoSellos > 0
                      // Backward-compat: `sellosDisponibles` con fallback a `stamps`
                      // (users legacy tienen solo `stamps` — sello-automatico.js escribe
                      // ambos hoy, pero data histórica puede tener solo uno).
                      && get(/databases/$(database)/documents/tenants/$(tid)/users/$(uid())).data
                           .get('sellosDisponibles',
                                get(/databases/$(database)/documents/tenants/$(tid)/users/$(uid())).data.get('stamps', 0))
                         >= request.resource.data.costoSellos;
        allow update: if autenticado() && (
          (resource.data.userId == uid()
           && resource.data.status == 'pending'
           && request.resource.data.status == 'cancelled'
           && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']))
          || esStaff(tid)
        );
        allow delete: if esAdmin(tid);
      }

      // ── chatbot/config — leído por el chat público (anónimo y autenticado).
      // El cliente del chat necesita poder leerlo para saber qué opciones,
      // saludo y keywords usar. La escritura queda solo para admins del tenant.
      match /chatbot/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── review_intents (Google reviews · tracking de intención) ──
      // El admin genera un link único que se manda al cliente por WhatsApp
      // ("¿cómo estuvo tu experiencia?"). El cliente abre la landing pública
      // /rate.html y califica. Si es positivo, la landing redirige a Google
      // y registra el momento; si es negativo, guarda feedback interno.
      // - Read PÚBLICO (la landing lo lee sin auth). La seguridad viene del
      //   token de 14 chars alfanuméricos que solo el admin conoce.
      // - Create solo admin del tenant.
      // - Update SIN auth (desde la landing) acotado a los campos que
      //   necesita cambiar y con status forward-only desde 'pending'.
      match /review_intents/{docId} {
        allow read: if true;
        allow create: if esAdmin(tid);
        allow update: if resource.data.status == 'pending'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                           'status', 'rating', 'ratedAt', 'redirectedToGoogleAt',
                           'feedbackText', 'landingOpenedAt',
                         ])
                      && request.resource.data.status in ['positive_redirected', 'negative_feedback', 'pending'];
        allow delete: if esAdmin(tid);
      }

      // ── productos ─────────────────────────────────────────────────
      // Admin controla precio/nombre/stock; staff puede decrementar stock
      // al vender (solo modifica el campo `stock`).
      match /productos/{docId} {
        allow read: if true;
        allow create, delete: if esAdmin(tid);
        allow update: if esAdmin(tid)
                      || (esStaff(tid)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
      }

      // ── referral_awards ──────────────────────────────────────────
      // Audit log del programa de referidos B2C (espejo del path root).
      // Escritura solo vía CF referidosRecompensaTenant (Admin SDK).
      match /referral_awards/{docId} {
        allow read: if esAdmin(tid);
        allow write: if false;
      }

      // ── giftCards ─────────────────────────────────────────────────
      // Mismo patrón que el path root: lectura pública para la consulta
      // de saldo sin auth (página /saldo-gift-card); escritura staff;
      // delete admin.
      match /giftCards/{docId} {
        allow read:   if true;
        allow create: if esStaff(tid);
        allow update: if esStaff(tid);
        allow delete: if esAdmin(tid);
      }

      // ── sorteos ───────────────────────────────────────────────────
      // · Lectura: PÚBLICA. La página /sorteo/:id (visitante sin sesión)
      //   necesita leer nombre/premio/fechas del sorteo. No expone PII —
      //   los participantes viven en subcolección con read restringido.
      // · Create + delete: solo admins.
      // · Update: admins libre; público SOLO puede incrementar
      //   participantes_count en exactamente +1 (sin tocar otro campo).
      //   Trade-off conocido: alguien podría spammear ese +1 sin crear
      //   participante; el subcolección /participantes es la fuente de
      //   verdad y se puede recontar si pasa.
      //
      // Subcolección /participantes: inscripción pública desde un link
      // externo (sin sesión). El `create` queda abierto con validaciones
      // mínimas anti-abuse (set de campos acotado, tope de tamaño y nada
      // de campos privilegiados). Read/update/delete quedan reservadas a
      // admins — los participantes contienen PII (nombre + teléfono/email).
      match /sorteos/{sorteoId} {
        allow read:           if true;
        allow create, delete: if esAdmin(tid);
        allow update: if esAdmin(tid)
                      || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantes_count'])
                          && request.resource.data.participantes_count is int
                          && request.resource.data.participantes_count == resource.data.get('participantes_count', 0) + 1);

        match /participantes/{participanteId} {
          allow read, update, delete: if esAdmin(tid);
          // `pronostico` es opcional — solo lo envían los sorteos tipo FUTBOL
          // (marcador { local, visita } con enteros 0-20 para evitar spam).
          allow create: if request.resource.data.keys().hasOnly(['nombre', 'telefono', 'email', 'createdAt', 'pronostico'])
                        && request.resource.data.nombre is string
                        && request.resource.data.nombre.size() > 0
                        && request.resource.data.nombre.size() <= 80
                        && (!('telefono' in request.resource.data)
                            || (request.resource.data.telefono is string
                                && request.resource.data.telefono.size() <= 30))
                        && (!('email' in request.resource.data)
                            || (request.resource.data.email is string
                                && request.resource.data.email.size() <= 120))
                        && (!('pronostico' in request.resource.data)
                            || (request.resource.data.pronostico is map
                                && request.resource.data.pronostico.local is int
                                && request.resource.data.pronostico.local >= 0
                                && request.resource.data.pronostico.local <= 20
                                && request.resource.data.pronostico.visita is int
                                && request.resource.data.pronostico.visita >= 0
                                && request.resource.data.pronostico.visita <= 20));
        }
      }

      // ── lookbook ──────────────────────────────────────────────────
      match /lookbook/{docId} {
        allow read: if true;
        allow create, delete: if esStaff(tid);
        allow update: if esStaff(tid)
          || (autenticado() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      }

      // ── settings ──────────────────────────────────────────────────
      match /settings/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── gastos ────────────────────────────────────────────────────
      match /gastos/{docId} {
        allow read, write: if esAdmin(tid);
      }

      // ── listaEspera (lista de espera del panel) ───────────────────
      // Solo staff la gestiona; el dashboard (Inicio) la lee para el KPI.
      match /listaEspera/{docId} {
        allow read, write: if esStaff(tid);
      }

      // ── _stats (resumen agregado por Cloud Function) ──────────────
      // Lo escribe la CF stats-aggregate (admin SDK); el panel solo lee.
      match /_stats/{docId} {
        allow read:  if esStaff(tid);
        allow write: if false;
      }

      // ── config ────────────────────────────────────────────────────
      match /config/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── configuracion ─────────────────────────────────────────────
      match /configuracion/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── anuncios (push publicitario al cliente) ──────────────────
      // Read: solo staff del tenant. Write: solo CF (via admin SDK).
      // Los admins ven el historial y estadísticas desde el panel.
      match /anuncios/{anuncioId} {
        allow read:  if esStaff(tid);
        allow write: if false; // solo Cloud Functions vía admin SDK

        match /recipients/{uid} {
          allow read:  if esStaff(tid);
          allow write: if false;
        }
      }

      // ── anuncios_optout (lista de opt-out del cliente) ───────────
      // El cliente puede leer/setear su propio opt-out. Staff lo lee para
      // respetar exclusiones. La CF también escribe/lee vía admin SDK.
      match /anuncios_optout/{userId} {
        allow read:   if autenticado() && (uid() == userId || esStaff(tid));
        allow create: if autenticado() && uid() == userId;
        allow update: if autenticado() && uid() == userId;
        allow delete: if autenticado() && uid() == userId;
      }

      // ── servicioFavorito ──────────────────────────────────────────
      match /servicioFavorito/{docId} {
        allow read:   if autenticado() && (
                         resource.data.email == request.auth.token.email
                      || esStaff(tid)
                      );
        allow create: if esStaff(tid)
                      || (autenticado()
                          && request.resource.data.email == request.auth.token.email);
        allow update: if esStaff(tid)
                      || (autenticado()
                          && resource.data.email == request.auth.token.email);
        allow delete: if esStaff(tid);
      }

      // ── clientes ──────────────────────────────────────────────────
      match /clientes/{docId} {
        allow read:   if esStaff(tid);
        allow create: if esStaff(tid)
                      || (autenticado()
                          && request.resource.data.uid == request.auth.uid
                          && !request.resource.data.keys().hasAny(['role', 'adminOverride']));
        allow update: if esStaff(tid)
                      || (autenticado()
                          && (resource.data.get('uid', '') == request.auth.uid
                              || resource.data.get('uid', null) == null
                              || resource.data.get('uid', '') == '')
                          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'adminOverride']));
        allow delete: if esAdmin(tid);
      }

      // ── users ─────────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if autenticado() && (uid() == userId || esStaff(tid));
        allow create: if autenticado()
                      && uid() == userId
                      && !request.resource.data.keys().hasAny(['role', 'tenantId', 'rol', 'adminOverride']);
        allow update: if autenticado()
                      && (uid() == userId || esStaff(tid))
                      && sinCambio('role')
                      && sinCambio('tenantId')
                      && sinCambio('rol');
        allow delete: if esAdmin(tid);
      }

      // ── userPublic ────────────────────────────────────────────────
      // Perfil público para "comparar con un amigo" (campos no sensibles).
      match /userPublic/{userId} {
        allow read:  if autenticado();
        allow write: if autenticado() && (uid() == userId || esStaff(tid));
      }

      // ── resenas ───────────────────────────────────────────────────
      match /resenas/{docId} {
        allow read:  if esStaff(tid);
        allow write: if esStaff(tid);
      }

      // ── corteLapiz (membresía a cuenta corriente · Yūgen) ─────────
      // Cuenta corriente por cliente. El staff la gestiona desde el panel;
      // la Cloud Function (admin SDK) le suma el cargo al completar la cita.
      // El propio cliente logueado puede LEER su cuenta (para saber, al
      // reservar en la web, si tiene la membresía activa) pero no escribirla.
      match /corteLapiz/{uid} {
        allow read:  if esStaff(tid) || (autenticado() && uid() == uid);
        allow write: if esStaff(tid);
        match /pagos/{pagoId} {
          allow read, write: if esStaff(tid);
        }
      }

      // ── admin_notes ───────────────────────────────────────────────
      match /admin_notes/{docId} {
        allow read, write: if esStaff(tid);
      }

      // ── chats ─────────────────────────────────────────────────────
      match /chats/{userId} {
        allow read, write: if autenticado() && (uid() == userId || esStaff(tid));

        match /messages/{msgId} {
          allow read:          if autenticado() && (uid() == userId || esStaff(tid));
          allow create:        if autenticado() && (uid() == userId || esStaff(tid));
          allow update, delete: if esAdmin(tid);
        }
      }

      // ── product_reservations ──────────────────────────────────────
      // Cliente crea su propia reserva (status='pending').
      // Staff puede crear ventas directas (status='delivered') desde el panel
      // (Venta Rápida en Productos o Productos del Ticket en Agenda) y
      // actualizar el estado o cualquier campo de la reserva.
      match /product_reservations/{docId} {
        allow read:   if autenticado() && (resource.data.get('userId', '') == uid() || esStaff(tid));
        allow create: if esStaff(tid)
                      || (autenticado()
                          && request.resource.data.userId == uid()
                          && request.resource.data.status == 'pending'
                          && !request.resource.data.keys().hasAny(['role', 'tenantId', 'adminOverride']));
        allow update: if esStaff(tid);
        allow delete: if esAdmin(tid);
      }

      // ── soporte_mensajes ──────────────────────────────────────────
      match /soporte_mensajes/{docId} {
        allow read:   if esAdmin(tid) || esBootstrap();
        allow create: if esAdmin(tid);
        allow update: if esBootstrap();
        allow delete: if esBootstrap();
      }

      // ── /publicidad_tv ─────────────────────────────────────────────
      match /publicidad_tv/{docId} {
        allow read: if true;
        allow write: if esStaff(tid);
      }
      
      // ── Academia ───────────────────────────────────────────────────
      match /cursos_academia/{docId} {
        allow read, write: if esStaff(tid);
      }
      match /alumnos_academia/{docId} {
        allow read, write: if esStaff(tid);
      }
      match /material_academia/{docId} {
        allow read, write: if esStaff(tid);
      }

      // ── caja_sesiones ─────────────────────────────────────────────
      match /caja_sesiones/{docId} {
        allow read, write: if esStaff(tid);
      }

      // ── slotLocks ─────────────────────────────────────────────────
      // Fuente pública de ocupación para el widget de reservas (sin auth).
      match /slotLocks/{lockId} {
        allow read:   if true;
        allow create: if esStaff(tid)
                      || request.resource.data.keys().hasOnly(['citaId', 'creadoEn', 'fecha', 'hora', 'barberoId', 'duracion']);
        allow update: if esStaff(tid);
        allow delete: if esStaff(tid);
      }

      // ── fcm_tokens ────────────────────────────────────────────────
      // Cualquier usuario autenticado del tenant puede registrar su token push.
      match /fcm_tokens/{tokenId} {
        allow read:  if esStaff(tid);
        allow write: if autenticado();
      }
    }
  }
}
