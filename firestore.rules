rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins iniciales reconocidos siempre (bootstrap para poder inicializar la BD)
    function esBootstrapAdmin() {
      return request.auth != null
          && request.auth.token.email in [
               'ignaciiio.mate@gmail.com',
               'barrazanicolasfabian@gmail.com'
             ];
    }

    // Barbero activo: bootstrap admin O UID existe en /barberos con activo != false
    // Usa get('activo', true) para que documentos sin campo activo sean tratados como activos,
    // igual que la lógica JS (activo !== false).
    function esBarberoDoc(docData) {
      return docData.get('activo', true) != false;
    }
    function esBarbero() {
      return esBootstrapAdmin()
          || (request.auth != null
              && exists(/databases/$(database)/documents/barberos/$(request.auth.uid))
              && esBarberoDoc(get(/databases/$(database)/documents/barberos/$(request.auth.uid)).data));
    }

    // Admin/Jefe: bootstrap admin O barbero activo con rol 'admin' o 'jefe'
    function esAdmin() {
      return esBootstrapAdmin()
          || (request.auth != null
              && exists(/databases/$(database)/documents/barberos/$(request.auth.uid))
              && esBarberoDoc(get(/databases/$(database)/documents/barberos/$(request.auth.uid)).data)
              && get(/databases/$(database)/documents/barberos/$(request.auth.uid)).data.get('rol', 'barbero') in ['admin', 'jefe']);
    }

    // ── /barberos ────────────────────────────────────────────────────────────────
    // Lectura pública para que el widget de reservas cargue la lista de barberos.
    // Escritura restringida a admins (solo jefe/admin puede crear/borrar barberos).
    // Auto-registro: un barbero puede crear su propio documento {uid} con campos mínimos
    // cuando su doc original fue creado con ID auto-generado (no su UID).
    match /barberos/{barberoId} {
      allow read: if true;
      allow delete: if esAdmin();
      allow create: if esAdmin()
                    || (request.auth != null
                        && request.auth.uid == barberoId
                        && request.resource.data.get('activo', true) != false
                        && request.resource.data.keys().hasAll(['activo', '_mainDocId']));
      allow update: if esAdmin() || (request.auth != null && request.auth.uid == barberoId);

      // Subcolecciones (configuracion, horarios, etc.)
      match /{document=**} {
        allow read: if true;
        allow write: if esBarbero();
      }
    }

    // ── /citas ───────────────────────────────────────────────────────────────────
    // El flujo público (sin login) puede crear citas, barberos gestionan el resto.
    // Lectura permitida a cualquier usuario autenticado: barberos ven su agenda,
    // y el doc de enlace en /barberos/{uid} puede no existir aún en primera sesión.
    match /citas/{citaId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['fecha', 'hora', 'clienteNombre', 'clienteTelefono', 'estado'])
                    && request.resource.data.estado == 'Confirmado';
      allow update: if esBarbero()
                    || (request.auth != null
                        && resource.data.get('clienteUid', '') == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']));
      allow delete: if esBarbero();
    }

    // ── /servicios ───────────────────────────────────────────────────────────────
    match /servicios/{doc} {
      allow read: if true;
      allow write: if esBarbero();
    }

    // ── /configuracion ───────────────────────────────────────────────────────────
    match /configuracion/{doc} {
      allow read: if true;
      allow write: if esBarbero();
    }

    // ── /bloqueos ────────────────────────────────────────────────────────────────
    match /bloqueos/{doc} {
      allow read: if true;
      allow write: if esBarbero();
    }

    // ── /premios ─────────────────────────────────────────────────────────────────
    // Solo admin/jefe puede crear o borrar premios; lectura pública para el dashboard.
    match /premios/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── /fcm_tokens ──────────────────────────────────────────────────────────────
    // Cualquier usuario autenticado puede registrar/actualizar su token de push.
    match /fcm_tokens/{tokenId} {
      allow read: if esBarbero();
      allow write: if request.auth != null;
    }

    // ── /lookbook ────────────────────────────────────────────────────────────────
    match /lookbook/{docId} {
      allow read: if true;
      allow write: if esBarbero();
    }

    // ── /productos ───────────────────────────────────────────────────────────────
    match /productos/{docId} {
      allow read: if true;
      allow write: if esBarbero();
    }

    // ── /users ───────────────────────────────────────────────────────────────────
    // Cada cliente accede solo a su propio documento; barberos leen todos.
    match /users/{userId} {
      allow read:   if request.auth != null && (request.auth.uid == userId || esBarbero());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || esBarbero());
      allow delete: if request.auth != null && (request.auth.uid == userId || esAdmin());
    }

    // ── /tenants ─────────────────────────────────────────────────────────────────
    // Perfil y configuración del local (multi-tenant SaaS).
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if esAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if esAdmin();
      }
    }

    // ── /admin_notes ─────────────────────────────────────────────────────────────
    // Notas internas de CRM; solo visibles para el equipo.
    match /admin_notes/{docId} {
      allow read, write: if esBarbero();
    }

    // ── /barber_settings (legacy) ────────────────────────────────────────────────
    match /barber_settings/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── /settings ────────────────────────────────────────────────────────────────
    // Configuración general del local (nombre, dirección, horario, redes sociales).
    match /settings/{docId} {
      allow read: if esBarbero();
      allow write: if esAdmin();
    }

    // ── /gastos ──────────────────────────────────────────────────────────────────
    // Registro de egresos; datos financieros sensibles, solo visibles para admin/jefe.
    match /gastos/{docId} {
      allow read, write: if esAdmin();
    }
  }
}
