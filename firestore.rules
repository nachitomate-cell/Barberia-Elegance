rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    //  FUNCIONES AUXILIARES
    //
    //  Toda la lógica se basa en Custom Claims (JWT de Firebase Auth).
    //  Los claims son asignados por Cloud Functions y son inmutables
    //  desde el cliente — eliminan la necesidad de leer Firestore en
    //  cada evaluación de regla.
    //
    //  Estructura de claims esperada:
    //    { role: 'admin' | 'jefe' | 'barbero', tenantId: string }
    // ═══════════════════════════════════════════════════════════════

    function autenticado() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Lectura segura de claims con valor por defecto vacío
    function rol() {
      return request.auth.token.get('role', '');
    }

    function tenantClaim() {
      return request.auth.token.get('tenantId', '');
    }

    // ── Fallback de emergencia (bootstrap) ─────────────────────────
    function esBootstrap() {
      return autenticado()
          && request.auth.token.email in [
               'ignaciiio.mate@gmail.com',
               'barrazanicolasfabian@gmail.com'
             ];
    }

    // TEMP: fallback Firestore mientras los barberos no tengan Custom Claims.
    // Eliminar después de ejecutar migrarClaimsExistentes() y que todos
    // cierren sesión y vuelvan a abrir.
    function esBarberoFirestore(tid) {
      return autenticado() && (
        tid == 'elegance'
          ? exists(/databases/$(database)/documents/barberos/$(request.auth.uid))
          : exists(/databases/$(database)/documents/tenants/$(tid)/barberos/$(request.auth.uid))
      );
    }

    // ── Pertenencia a tenant ────────────────────────────────────────
    function esDeTenant(tid) {
      return autenticado() && tenantClaim() == tid;
    }

    // ── Roles ───────────────────────────────────────────────────────
    function esStaff(tid) {
      return (esDeTenant(tid) && rol() in ['admin', 'jefe', 'barbero'])
          || esBootstrap()
          || esBarberoFirestore(tid); // TEMP: eliminar post-migración
    }

    function esAdmin(tid) {
      return (esDeTenant(tid) && rol() in ['admin', 'jefe'])
          || esBootstrap();
    }

    function esAdminEstricto(tid) {
      return (esDeTenant(tid) && rol() == 'admin')
          || esBootstrap();
    }

    // ── Validación de campos ────────────────────────────────────────

    // Verifica que un campo NO fue modificado en un update
    function sinCambio(campo) {
      return !(campo in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Booking público válido: campos mínimos + estado inicial correcto
    // + no inyecta campos de privilegio
    function bookingPublicoValido() {
      return request.resource.data.keys().hasAll(['fecha', 'hora', 'clienteNombre', 'estado'])
          && request.resource.data.estado in ['Confirmada', 'Pendiente']
          && !request.resource.data.keys().hasAny(['rol', 'role', 'tenantId', 'adminOverride', 'barberoRol']);
    }

    // ═══════════════════════════════════════════════════════════════
    //  ELEGANCE — colecciones raíz (tenant legacy/predeterminado)
    // ═══════════════════════════════════════════════════════════════

    // ── /barberos ──────────────────────────────────────────────────
    // Lectura pública: widget de reservas y agenda pública necesitan
    // listar barberos y su configuración (subcolección /configuracion).
    match /barberos/{barberoId} {
      allow read: if true;
      allow create: if esAdmin('elegance');
      allow update: if esAdmin('elegance')
                    || (esStaff('elegance')
                        && uid() == barberoId
                        && sinCambio('rol')
                        && sinCambio('disponible')
                        && sinCambio('comision'));
      allow delete: if esAdminEstricto('elegance');

      // Subcolecciones: configuración de horario, preferencias, etc.
      // Lectura pública para que la agenda y el widget de reservas funcionen.
      match /{subCol}/{docId} {
        allow read: if true;
        allow write: if esStaff('elegance');
      }
    }

    // ── /citas ─────────────────────────────────────────────────────
    // Creación pública sin auth (widget de reservas online) con
    // validación estricta de estructura.  Staff puede crear/editar.
    // Clientes solo pueden cancelar su propia cita.
    match /citas/{citaId} {
      allow read: if esStaff('elegance');
      allow create: if bookingPublicoValido()
                    || esStaff('elegance');
      allow update: if esStaff('elegance')
                    || (autenticado()
                        && resource.data.get('clienteUid', null) == uid()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                        && request.resource.data.estado == 'Cancelada');
      allow delete: if esAdmin('elegance');
    }

    // ── /servicios ─────────────────────────────────────────────────
    match /servicios/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /bloqueos ──────────────────────────────────────────────────
    match /bloqueos/{docId} {
      allow read: if true;
      allow write: if esStaff('elegance');
    }

    // ── /premios ───────────────────────────────────────────────────
    match /premios/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /productos ─────────────────────────────────────────────────
    match /productos/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /lookbook ──────────────────────────────────────────────────
    match /lookbook/{docId} {
      allow read: if true;
      allow write: if esStaff('elegance');
    }

    // ── /settings ──────────────────────────────────────────────────
    // Configuración del local: solo staff la lee, solo admin escribe.
    match /settings/{docId} {
      allow read: if esStaff('elegance');
      allow write: if esAdmin('elegance');
    }

    // ── /gastos ────────────────────────────────────────────────────
    // Datos financieros: acceso exclusivo a admin/jefe.
    match /gastos/{docId} {
      allow read, write: if esAdmin('elegance');
    }

    // ── /config ────────────────────────────────────────────────────
    // Configuración UI (activa productos, etc.).
    match /config/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /users ─────────────────────────────────────────────────────
    // Un cliente accede solo a su propio doc.
    // Staff puede leer todos; nadie puede modificar role/tenantId/rol.
    match /users/{userId} {
      allow read: if autenticado() && (uid() == userId || esStaff('elegance'));
      allow create: if autenticado()
                    && uid() == userId
                    && !request.resource.data.keys().hasAny(['role', 'tenantId', 'rol', 'adminOverride']);
      allow update: if autenticado()
                    && (uid() == userId || esStaff('elegance'))
                    && sinCambio('role')
                    && sinCambio('tenantId')
                    && sinCambio('rol');
      allow delete: if esAdmin('elegance');
    }

    // ── /admin_notes ───────────────────────────────────────────────
    match /admin_notes/{docId} {
      allow read, write: if esStaff('elegance');
    }

    // ── /fcm_tokens ────────────────────────────────────────────────
    // Cualquier usuario autenticado puede registrar su token push.
    match /fcm_tokens/{tokenId} {
      allow read: if esStaff('elegance');
      allow write: if autenticado();
    }

    // ── /barber_settings (legacy) ───────────────────────────────────
    match /barber_settings/{docId} {
      allow read: if true;
      allow write: if esAdmin('elegance');
    }

    // ── /product_reservations ──────────────────────────────────────
    // Cliente crea su propia reserva. Staff lee y actualiza el estado.
    match /product_reservations/{docId} {
      allow read:   if autenticado() && (resource.data.get('userId', '') == uid() || esStaff('elegance'));
      allow create: if autenticado()
                    && request.resource.data.userId == uid()
                    && request.resource.data.status == 'pending'
                    && !request.resource.data.keys().hasAny(['role', 'tenantId', 'adminOverride']);
      allow update: if esStaff('elegance')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if esAdmin('elegance');
    }

    // ── /chats ─────────────────────────────────────────────────────
    // El cliente lee/escribe solo su propio chat. Staff lee/escribe todos.
    match /chats/{userId} {
      allow read, write: if autenticado() && (uid() == userId || esStaff('elegance'));

      match /messages/{msgId} {
        allow read:          if autenticado() && (uid() == userId || esStaff('elegance'));
        allow create:        if autenticado() && (uid() == userId || esStaff('elegance'));
        allow update, delete: if esAdmin('elegance');
      }
    }

    // ═══════════════════════════════════════════════════════════════
    //  MULTI-TENANT — /tenants/{tid}/...
    //  El tenantId del usuario (claim) debe coincidir con {tid}.
    // ═══════════════════════════════════════════════════════════════

    match /tenants/{tid} {
      allow read: if true;
      allow write: if esAdmin(tid);

      // ── barberos ─────────────────────────────────────────────────
      match /barberos/{barberoId} {
        allow read: if true;
        allow create: if esAdmin(tid);
        allow update: if esAdmin(tid)
                      || (esStaff(tid)
                          && uid() == barberoId
                          && sinCambio('rol')
                          && sinCambio('disponible')
                          && sinCambio('comision'));
        allow delete: if esAdminEstricto(tid);

        match /{subCol}/{docId} {
          allow read: if true;
          allow write: if esStaff(tid);
        }
      }

      // ── citas (panel admin) ───────────────────────────────────────
      match /citas/{citaId} {
        allow read: if esStaff(tid);
        allow create: if bookingPublicoValido() || esStaff(tid);
        allow update: if esStaff(tid)
                      || (autenticado()
                          && resource.data.get('clienteUid', null) == uid()
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                          && request.resource.data.estado == 'Cancelada');
        allow delete: if esAdmin(tid);
      }

      // ── bookings (flujo público web) ──────────────────────────────
      match /bookings/{bookingId} {
        allow read: if esStaff(tid);
        allow create: if bookingPublicoValido() || esStaff(tid);
        allow update: if esStaff(tid)
                      || (autenticado()
                          && resource.data.get('clienteUid', null) == uid()
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                          && request.resource.data.estado == 'Cancelada');
        allow delete: if esAdmin(tid);
      }

      // ── servicios ─────────────────────────────────────────────────
      match /servicios/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── bloqueos ──────────────────────────────────────────────────
      match /bloqueos/{docId} {
        allow read: if true;
        allow write: if esStaff(tid);
      }

      // ── premios ───────────────────────────────────────────────────
      match /premios/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── productos ─────────────────────────────────────────────────
      match /productos/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── lookbook ──────────────────────────────────────────────────
      match /lookbook/{docId} {
        allow read: if true;
        allow write: if esStaff(tid);
      }

      // ── settings ──────────────────────────────────────────────────
      match /settings/{docId} {
        allow read: if esStaff(tid);
        allow write: if esAdmin(tid);
      }

      // ── gastos ────────────────────────────────────────────────────
      match /gastos/{docId} {
        allow read, write: if esAdmin(tid);
      }

      // ── config ────────────────────────────────────────────────────
      match /config/{docId} {
        allow read: if true;
        allow write: if esAdmin(tid);
      }

      // ── users ─────────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if autenticado() && (uid() == userId || esStaff(tid));
        allow create: if autenticado()
                      && uid() == userId
                      && !request.resource.data.keys().hasAny(['role', 'tenantId', 'rol', 'adminOverride']);
        allow update: if autenticado()
                      && (uid() == userId || esStaff(tid))
                      && sinCambio('role')
                      && sinCambio('tenantId')
                      && sinCambio('rol');
        allow delete: if esAdmin(tid);
      }

      // ── admin_notes ───────────────────────────────────────────────
      match /admin_notes/{docId} {
        allow read, write: if esStaff(tid);
      }

      // ── chats ─────────────────────────────────────────────────────
      match /chats/{userId} {
        allow read, write: if autenticado() && (uid() == userId || esStaff(tid));

        match /messages/{msgId} {
          allow read:          if autenticado() && (uid() == userId || esStaff(tid));
          allow create:        if autenticado() && (uid() == userId || esStaff(tid));
          allow update, delete: if esAdmin(tid);
        }
      }

      // ── product_reservations ──────────────────────────────────────
      match /product_reservations/{docId} {
        allow read:   if autenticado() && (resource.data.get('userId', '') == uid() || esStaff(tid));
        allow create: if autenticado()
                      && request.resource.data.userId == uid()
                      && request.resource.data.status == 'pending'
                      && !request.resource.data.keys().hasAny(['role', 'tenantId', 'adminOverride']);
        allow update: if esStaff(tid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
        allow delete: if esAdmin(tid);
      }
    }
  }
}
